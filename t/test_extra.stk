## t/test_extra.stk — assertion tests for the v0.7.0 additions across all
## five sublibs. Pure stryke; every function tested here was verified absent
## from stryke core before it was added (no builtin duplicated).

use Utils

# ── Utils::Num ───────────────────────────────────────────────────────
assert_eq Utils::Num::is_close(0.1 + 0.2, 0.3),     1, "is_close: float-equal within tol"
assert_eq Utils::Num::is_close(1, 1.5),             0, "is_close: far apart"
assert_eq Utils::Num::is_close(100, 100.0000001),   1, "is_close: relative tolerance"
assert_ok Utils::Num::is_close(Utils::Num::to_degrees(Utils::Num::to_radians(90)), 90),
    "to_radians/to_degrees round-trip ≈ 90"
assert_eq Utils::Num::round_sig(3.14159, 3),        3.14,   "round_sig: 3 sig figs"
assert_eq Utils::Num::round_sig(12345, 2),          12000,  "round_sig: magnitude preserved"
assert_eq Utils::Num::round_sig(0, 3),              0,      "round_sig: zero"
assert_eq Utils::Num::clamp01(1.5),                 1,      "clamp01: above range"
assert_eq Utils::Num::clamp01(-0.2),                0,      "clamp01: below range"
assert_eq Utils::Num::clamp01(0.5),                 0.5,    "clamp01: in range"

# remap: linear rescale between two ranges.
assert_eq Utils::Num::remap(5, 0, 10, 0, 100),      50,     "remap: midpoint scales to 50"
assert_eq Utils::Num::remap(0, 0, 10, 20, 30),      20,     "remap: low end maps to out_lo"
assert_eq Utils::Num::remap(10, 0, 10, 20, 30),     30,     "remap: high end maps to out_hi"
assert_eq Utils::Num::remap(15, 0, 10, 0, 100),     150,    "remap: extrapolates outside the input range"
assert_eq Utils::Num::remap(5, 0, 10, 100, 0),      50,     "remap: inverted output range"
assert_dies fn { Utils::Num::remap(1, 5, 5, 0, 1) },        "remap: rejects a degenerate input range"

# gcd: Euclidean greatest common divisor.
assert_eq Utils::Num::gcd(12, 18),    6,  "gcd: 12,18 → 6"
assert_eq Utils::Num::gcd(17, 5),     1,  "gcd: coprime → 1"
assert_eq Utils::Num::gcd(0, 5),      5,  "gcd: gcd(0,n) → |n|"
assert_eq Utils::Num::gcd(0, 0),      0,  "gcd: gcd(0,0) → 0"
assert_eq Utils::Num::gcd(-12, 8),    4,  "gcd: ignores sign"
assert_eq Utils::Num::gcd(1920, 1080), 120, "gcd: aspect ratio reduce (16:9)"

# ── Utils::List ──────────────────────────────────────────────────────
assert_eq Utils::List::count_where([1, 2, 3, 4], fn ($x) { $x > 2 }), 2, "count_where: 2 over 2"
assert_eq Utils::List::count_where([], fn ($x) { 1 }),                0, "count_where: empty list"

# transpose: rows ↔ columns.
val $t = Utils::List::transpose([[1, 2, 3], [4, 5, 6]])
assert_eq join(",", @{ $t->[0] }), "1,4", "transpose: first column"
assert_eq join(",", @{ $t->[2] }), "3,6", "transpose: last column"
assert_eq scalar(@$t),             3,     "transpose: 2x3 → 3x2"
# square matrix transposes its diagonal in place.
assert_eq join("|", map { join(",", @$_) } @{ Utils::List::transpose([[1, 2], [3, 4]]) }), "1,3|2,4", "transpose: 2x2"
assert_eq scalar(@{ Utils::List::transpose([]) }), 0, "transpose: empty matrix"
assert_dies fn { Utils::List::transpose([[1, 2], [3]]) }, "transpose: rejects ragged rows"

# ── Utils::Hash ──────────────────────────────────────────────────────
val $dd = Utils::Hash::deep_delete({ a => { b => 1, c => 2 } }, "a.b")
assert_ok !exists($dd->{a}{b}),  "deep_delete: leaf removed"
assert_eq $dd->{a}{c},      2,   "deep_delete: sibling kept"

val $def = Utils::Hash::defaults({ a => 1 }, { a => 9, b => 2 })
assert_eq $def->{a},        1,   "defaults: existing key wins"
assert_eq $def->{b},        2,   "defaults: missing key filled"

val @dk = @{ Utils::Hash::deep_keys({ a => { b => 1 }, c => 2 }) }
assert_eq join(",", @dk),   "a.b,c", "deep_keys: sorted dotted paths"
val @dv = @{ Utils::Hash::deep_values({ a => { b => 1 }, c => 2 }) }
assert_eq join(",", @dv),   "1,2",   "deep_values: in deep_keys order"

val $cv = Utils::Hash::count_values({ a => 1, b => 1, c => 2 })
assert_eq $cv->{1},         2,   "count_values: two keys map to 1"
assert_eq $cv->{2},         1,   "count_values: one key maps to 2"

val $me = Utils::Hash::map_entries({ a => 1 }, fn ($k, $v) { (uc($k), $v * 10) })
assert_eq $me->{A},         10,  "map_entries: key and value transformed"

val $mw = Utils::Hash::merge_with(fn ($x, $y) { $x + $y }, { a => 1 }, { a => 2, b => 3 })
assert_eq $mw->{a},         3,   "merge_with: collision combined"
assert_eq $mw->{b},         3,   "merge_with: non-collision passed through"

val $pb = Utils::Hash::pick_by({ a => 1, b => 2 }, fn ($k, $v) { $v > 1 })
assert_ok !exists($pb->{a}), "pick_by: a dropped"
assert_eq $pb->{b},         2,   "pick_by: b kept"

val $hd = Utils::Hash::hash_diff({ a => 1, b => 2 }, { a => 9, c => 3 })
assert_eq $hd->{changed}{a}[0], 1, "hash_diff: changed old value"
assert_eq $hd->{changed}{a}[1], 9, "hash_diff: changed new value"
assert_eq $hd->{removed}{b},    2, "hash_diff: removed key"
assert_eq $hd->{added}{c},      3, "hash_diff: added key"

# ── Utils::Time ──────────────────────────────────────────────────────
assert_eq Utils::Time::quarter(1),   1, "quarter: Jan → Q1"
assert_eq Utils::Time::quarter(4),   2, "quarter: Apr → Q2"
assert_eq Utils::Time::quarter(12),  4, "quarter: Dec → Q4"
assert_dies sub { Utils::Time::quarter(13) }, "quarter: out of range dies"

assert_eq Utils::Time::is_same_day(0, 3600),   1, "is_same_day: same UTC day"
assert_eq Utils::Time::is_same_day(0, 90000),  0, "is_same_day: next day"

# 1970-01-01 is Thursday (wday 4). Next Thursday strictly after is +7 days.
assert_eq Utils::Time::next_weekday(0, 4), 604800, "next_weekday: same weekday → +7 days"
# Next Friday (wday 5) after epoch 0 is +1 day.
assert_eq Utils::Time::next_weekday(0, 5), 86400,  "next_weekday: tomorrow"

# ── Utils::Path ──────────────────────────────────────────────────────
assert_eq Utils::Path::is_hidden("/a/.env"),  1, "is_hidden: dotfile"
assert_eq Utils::Path::is_hidden("/a/b"),     0, "is_hidden: plain"
assert_eq Utils::Path::expand_user("~/x"),    "$ENV{HOME}/x", "expand_user: tilde → HOME"
assert_eq Utils::Path::expand_user("/no/tilde"), "/no/tilde",  "expand_user: non-tilde unchanged"
assert_eq Utils::Path::sibling("/a/b", "c"),  "/a/c", "sibling: replaces final component"
assert_eq join(",", @{ Utils::Path::ancestors("/a/b/c") }), "/a/b,/a,/", "ancestors: nearest first"
assert_eq Utils::Path::with_stem("/a/b.txt", "c"), "/a/c.txt", "with_stem: keeps extension"
assert_eq Utils::Path::with_stem("/a/b", "c"),     "/a/c",     "with_stem: no extension"
assert_eq Utils::Path::common_ancestor(["/a/b/x", "/a/b/y", "/a/c"]), "/a", "common_ancestor"

# ── Utils::String ────────────────────────────────────────────────────
assert_eq Utils::String::remove_prefix("unwrap", "un"), "wrap", "remove_prefix: present"
assert_eq Utils::String::remove_prefix("xyz", "ab"),    "xyz",  "remove_prefix: absent"
assert_eq Utils::String::remove_suffix("file.bak", ".bak"), "file", "remove_suffix: present"
assert_eq Utils::String::remove_suffix("xyz", "ab"),        "xyz",  "remove_suffix: absent"

test_run
